# Base URL for duffleup-api, INCLUDING the /api/v1 prefix. The typed API client
# (src/lib/api) and EarlyAccessForm both pass resource-relative paths under it
# (e.g. /mood-config). Live data (SSR fetches) needs a local backend running,
# or point this at prod: https://api.duffleup.in/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
